# AI Model Gateway 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================
# 钉钉平台配置
# ============================================
AI_APP_PLATFORM_ORIGIN=https://ai-app.dingtalk.com

# ============================================
# Supabase 数据库配置
# ============================================
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================
# 应用配置
# ============================================
APP_ID=your_app_id
CORP_ID=your_corp_id

# ============================================
# 存储配置（可选）
# ============================================
BUCKET_NAME=your_bucket_name
